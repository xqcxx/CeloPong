# ==============================================
# Backend Environment Example
# Mainnet values are active below.
# For testnet, replace the mainnet chain values with the testnet section values.
# ==============================================

# ==============================================
# Shared backend settings
# ==============================================
NODE_ENV=production
PORT=8080
MONGODB_URI=mongodb://mongo:27017/pong-it
SIGNING_WALLET_PRIVATE_KEY=0x_your_backend_signer_private_key

# CORS / frontend origins
# Supports comma-separated origins.
FRONTEND_URL=http://localhost:3000,https://frontend-rosy-iota-16.vercel.app
# FRONTEND_URL_FALLBACK=
# FRONTEND_URL_DEV_ORIGINS=
# FRONTEND_URL_ALLOW_ALL=false

# Optional backend settings
# PLAYER_SERVICE_URL=http://localhost:5001
SOCKET_HEADER_LOGS=false
KEEP_RENDER_ALIVE=false

# ==============================================
# Mainnet chain configuration
# Deploy the escrow from this branch before production rollout. The previous
# escrow does not enforce late joins or support abandoned-match refunds.
# ==============================================
PONG_ESCROW_ADDRESS=0x_your_new_mainnet_escrow_address
CELO_RPC_URL=https://forno.celo.org
CELO_CHAIN_ID=42220

# ==============================================
# Testnet chain configuration
# Swap these in when running against Celo Sepolia.
# ==============================================
# PONG_ESCROW_ADDRESS=0x_your_new_testnet_escrow_address
# CELO_RPC_URL=https://celo-sepolia.g.alchemy.com/v2/your_alchemy_key
# CELO_CHAIN_ID=11142220
