# ==============================================
# CRA Frontend Environment Example
# Use the mainnet section to run against Celo mainnet.
# Switch REACT_APP_ENVIRONMENT to testnet to use the testnet values below.
# ==============================================

# ==============================================
# Shared frontend settings
# ==============================================
REACT_APP_ENVIRONMENT=mainnet
REACT_APP_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
REACT_APP_BACKEND_URL=http://localhost:8080
# REACT_APP_BACKEND_URL_FALLBACK=
# REACT_APP_SHOW_BACKEND_URL_BANNER=true

# ==============================================
# Mainnet configuration
# ==============================================
REACT_APP_MAINNET_PONG_ESCROW_ADDRESS=0xb2f6b1e7a2db0f9aa9ef7167b71620991a1506fc
REACT_APP_MAINNET_cUSD=0x765DE816845861e75A25fCA122bb6898B8B1282a
REACT_APP_MAINNET_USDC=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
REACT_APP_MAINNET_USDT=0x48065fbbe25f71c9282ddf5e1cd6d6a887483d5e
REACT_APP_MAINNET_USDC_ADAPTER=0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B
REACT_APP_MAINNET_USDT_ADAPTER=0x0e2a3e05bc9a16f5292a6170456a710cb89c6f72
REACT_APP_MAINNET_EXPLORER=https://celoscan.io

